PORT=3001
FRONTEND_URL=http://localhost:3000

# ADR-0053: backend bazy + storage.
#   PATRON_DB_BACKEND=sqlite (default) - single-user desktop, zero-cloud.
#     Baza w pliku (PATRON_DB_PATH lub %APPDATA%/PATRON/patron.db), auth bypass
#     (jeden lokalny user), zero Dockera/Supabase. SUPABASE_* nizej ignorowane.
#   PATRON_DB_BACKEND=supabase - multi-tenant SaaS (Postgres + GoTrue). Wymaga SUPABASE_*.
#   PATRON_STORAGE=fs (default gdy brak R2) - dokumenty na lokalnym FS
#     (PATRON_STORAGE_DIR lub %APPDATA%/PATRON/sprawy/). =r2 dla Cloudflare R2.
PATRON_DB_BACKEND=sqlite
# PATRON_DB_PATH=
# PATRON_STORAGE=fs
# PATRON_STORAGE_DIR=
# PATRON_LOCAL_USER_ID=00000000-0000-0000-0000-000000000001
# PATRON_LOCAL_USER_EMAIL=local@patron
# PATRON_LOCAL_USER_NAME=Mecenas

# ADR-0054: hybrid retrieval (wektor sqlite-vec + BM25 FTS5 + graf cytowan).
#   PATRON_EMBED_MODEL - model embeddera transformers.js (lokalny, zero-cloud).
#   PATRON_EMBED_DIM   - wymiar wektora; MUSI byc zgodny z modelem (e5-small=384,
#                        e5-large=1024). Zmiana => re-index korpusu.
#   PATRON_RRF_K       - stala reciprocal rank fusion (default 60).
#   PATRON_DISABLE_VEC - =1 wylacza warstwe wektorowa (sqlite-vec/model
#                        niedostepny); BM25 + graf dzialaja dalej.
# PATRON_EMBED_MODEL=Xenova/multilingual-e5-small
# PATRON_EMBED_DIM=384
# PATRON_RRF_K=60
# PATRON_DISABLE_VEC=

# HMAC key used to sign /download/:token URLs. Required at startup (oba tryby).
# Generate with: openssl rand -hex 32
# Use a dedicated secret distinct from SUPABASE_SECRET_KEY.
DOWNLOAD_SIGNING_SECRET=replace-with-a-random-32-byte-hex-string

# Tylko dla PATRON_DB_BACKEND=supabase:
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SECRET_KEY=your-supabase-service-role-key

# Tylko dla PATRON_STORAGE=r2:
R2_ENDPOINT_URL=https://your-account-id.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_NAME=patron

GEMINI_API_KEY=your-gemini-key
ANTHROPIC_API_KEY=your-anthropic-key
OPENAI_API_KEY=your-openai-key
RESEND_API_KEY=your-resend-key
USER_API_KEYS_ENCRYPTION_SECRET=your-long-random-secret

# ADR-0036: hybrid auto-trigger Merkle audit root.
# Compute nastepuje gdy nowych eventow >= COUNT_THRESHOLD LUB ostatni root sprzed >= INTERVAL_HOURS.
# CHECK_INTERVAL_MS = jak czesto scheduler sprawdza warunki (default 1h).
PATRON_MERKLE_AUTO_COUNT_THRESHOLD=1000
PATRON_MERKLE_AUTO_INTERVAL_HOURS=24
PATRON_MERKLE_CHECK_INTERVAL_MS=3600000

# ADR-0034: whitelist adminow (CSV, lowercase, trim).
# Pusta wartosc = brak adminow (kazde wywolanie requireAdmin -> 403).
# Edycja wymaga restartu kontenera. Audyt zmian = git history tego pliku.
PATRON_ADMIN_EMAILS=
