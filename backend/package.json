    "better-sqlite3": "npm:better-sqlite3-multiple-ciphers@^12.10.0",
    "cors": "^2.8.5",
    "docx": "^9.5.0",
    "dotenv": "^17.4.1",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.1",
    "fast-diff": "^1.3.0",
    "fast-xml-parser": "^5.7.1",
    "helmet": "^8.1.0",
    "jszip": "^3.10.1",
    "libreoffice-convert": "^1.6.0",
    "mammoth": "^1.9.0",
    "multer": "^1.4.5-lts.2",
